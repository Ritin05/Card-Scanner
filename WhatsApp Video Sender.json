    {
      "parameters": {
        "jsCode": "// Collect unique WhatsApp numbers from each row\nconst items = $input.all();\nconst mediaId = $('Save Media ID').first().json.media_id;\nconst phoneNumberId = $('Save Media ID').first().json.phone_number_id;\nconst results = [];\nconst sentNumbers = new Set();\n\nfor (const item of items) {\n  const phoneNumber = (item.json['Phone Number'] || '').toString().trim().replace(/[\\s\\-()]/g, '');\n  const mobileNumber = (item.json['Mobile Number'] || '').toString().trim().replace(/[\\s\\-()]/g, '');\n  const customerName = item.json['Customer Name'] || '';\n  const companyName = item.json['Company Name'] || '';\n\n  if (phoneNumber && phoneNumber.length >= 10 && !sentNumbers.has(phoneNumber)) {\n    sentNumbers.add(phoneNumber);\n    results.push({\n      json: {\n        to_number: phoneNumber,\n        customer_name: customerName,\n        company_name: companyName,\n        media_id: mediaId,\n        phone_number_id: phoneNumberId,\n        source: 'Phone Number'\n      }\n    });\n  }\n\n  if (mobileNumber && mobileNumber.length >= 10 && !sentNumbers.has(mobileNumber)) {\n    sentNumbers.add(mobileNumber);\n    results.push({\n      json: {\n        to_number: mobileNumber,\n        customer_name: customerName,\n        company_name: companyName,\n        media_id: mediaId,\n        phone_number_id: phoneNumberId,\n        source: 'Mobile Number'\n      }\n    });\n  }\n}\n\nreturn results;"
      },
      "id": "a1b2c3d4-0004-4000-8000-000000000004",
      "name": "Collect Unique Numbers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1720,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{ $json.phone_number_id }}/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"messaging_product\": \"whatsapp\", \"to\": $json.to_number, \"type\": \"template\", \"template\": { \"name\": \"video_share\", \"language\": { \"code\": \"en\" }, \"components\": [ { \"type\": \"header\", \"parameters\": [ { \"type\": \"video\", \"video\": { \"id\": $json.media_id } } ] } ] } }) }}",
        "options": {
          "batching": {
            "batch": {
              "batchSize": 1,
              "batchInterval": 2000
            }
          }
        }
      },
      "id": "a1b2c3d4-0005-4000-8000-000000000005",
      "name": "Send video_share Template",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        1940,
        400
      ],
      "continueOnFail": true,
