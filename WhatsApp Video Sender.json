      "id": "a1b2c3d4-0006-4000-8000-000000000006",
      "name": "Message Sent?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        2160,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log ALL successful sends\nconst items = $input.all();\nconst results = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const input = items[i].json;\n  results.push({\n    json: {\n      status: '✅ Video Sent Successfully',\n      message_id: input.messages ? input.messages[0].id : 'unknown',\n      number: input.contacts ? input.contacts[0].input : 'unknown',\n      wa_id: input.contacts ? input.contacts[0].wa_id : 'unknown'\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "a1b2c3d4-0007-4000-8000-000000000007",
      "name": "Log Success",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2380,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log ALL failed sends\nconst items = $input.all();\nconst results = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const input = items[i].json;\n  results.push({\n    json: {\n      status: '❌ Video Send Failed',\n      error: input.error ? input.error.message : JSON.stringify(input)\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "a1b2c3d4-0008-4000-8000-000000000008",
      "name": "Log Failed",
